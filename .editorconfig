# EditorConfig for ADSentinel
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.{md,txt}]
trim_trailing_whitespace = false

[*.ps1]
indent_size = 4

[*.html]
indent_size = 2

[Makefile]
indent_style = tab
