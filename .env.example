# ADSentinel Configuration
# Copy to .env and fill in your values

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Flask debug mode (set to True for development only)
FLASK_DEBUG=False

# Server host/port
HOST=0.0.0.0
PORT=5000

# Path to mock data file (leave blank to use live AD)
MOCK_DATA_PATH=mock_dc_status.json
