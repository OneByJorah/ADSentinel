# ADSentinel Configuration
# Copy this file to .env and fill in your values

# Flask secret key for session signing (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# Host and port for the Flask server
HOST=0.0.0.0
PORT=5000

# Path to mock DC status JSON file
MOCK_DATA_PATH=mock_dc_status.json

# Set to "true" to enable debug mode (development only)
DEBUG=false

# TLS/SSL certificate and key paths (optional, for HTTPS)
# SSL_CERT=path/to/cert.pem
# SSL_KEY=path/to/key.pem

# Basic auth credentials for admin dashboard (optional)
# BASIC_AUTH_USERNAME=admin
# BASIC_AUTH_PASSWORD=change-me
